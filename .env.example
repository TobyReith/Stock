NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server-only (Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Vision-Provider (MHD-OCR, Phase 1)
ANTHROPIC_API_KEY=

# Web Push VAPID (Phase 2) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
