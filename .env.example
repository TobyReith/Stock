NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server-only (Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Vision-Provider (MHD-OCR, Phase 1)
ANTHROPIC_API_KEY=

# Web Push VAPID (Phase 2) — generate: npx web-push generate-vapid-keys
# The public key is shipped to the browser and used as `applicationServerKey`
# in PushManager.subscribe(); the private key signs outgoing pushes on the
# cron endpoint. `VAPID_SUBJECT` must be a valid mailto: or https:// URL —
# push services use it to contact the app author if a subscription misbehaves.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Cron auth (Phase 2) — Vercel Cron sends this as `Authorization: Bearer …`
# to /api/cron/*. Generate any random 32+ char string.
CRON_SECRET=
